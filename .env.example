# Supabase Environment Variables
# Copy file này thành .env.local và điền giá trị thật

# Dùng cho frontend (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Dùng cho scripts/push-schema.mjs (KHÔNG commit vào git)
# Lấy tại: Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Kimi K2 API — Tầng 1 (sinh vụ án) + Tầng 2 (AI hung thủ)
# Lấy tại: https://platform.moonshot.cn/console/api-keys
VITE_KIMI_API_KEY=your-kimi-api-key-here
# Override model nếu cần (mặc định: kimi-k2)
# VITE_KIMI_MODEL=kimi-k2.5
