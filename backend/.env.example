# Backend API Configuration
PORT=3001
FRONTEND_URL=http://localhost:5173

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini API Configuration
# Chat/Text Models (theo thứ tự chất lượng):
# - gemini-2.0-pro-exp-02-05: Mạnh nhất, viết văn hay nhất
# - gemini-2.0-flash: Nhanh, cân bằng tốt
# - gemini-1.5-pro: Model cũ hơn
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-pro-exp-02-05

# Brave Search API (optional — enhances case generation with real knowledge)
# Get a free key at https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Node Environment
NODE_ENV=development
